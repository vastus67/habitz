{
  "project_name": "Habitz",
  "app_type": "Mobile-First Web App (PWA)",
  "target_audience": "Fitness-focused consumers",
  "design_philosophy": {
    "archetype": "The Performance Pro",
    "vibe": "Elite Athleticism, Dark Mode, Precision, High Contrast",
    "principles": [
      "Mobile-First Layouts: Stacked columns, touch-friendly targets (min 44px).",
      "Dense but Breathing: Tight data density (gap-4) but generous container padding (p-6).",
      "Dark Mode Default: OLED-friendly blacks with neon accents.",
      "Motion: Smooth page transitions, staggered entrance for lists."
    ]
  },
  "typography": {
    "font_family": {
      "headings": "Manrope",
      "body": "Manrope"
    },
    "weights": {
      "headings": "800 (ExtraBold)",
      "subheadings": "600 (SemiBold)",
      "body": "400 (Regular)"
    },
    "scale": {
      "h1": "text-4xl md:text-5xl tracking-tighter leading-none",
      "h2": "text-3xl tracking-tight",
      "h3": "text-2xl tracking-tight",
      "body": "text-base leading-relaxed text-muted-foreground",
      "label": "text-xs font-bold uppercase tracking-widest text-muted-foreground"
    }
  },
  "colors": {
    "palette": {
      "background": "#09090b",
      "foreground": "#fafafa",
      "card": "#18181b",
      "card_foreground": "#fafafa",
      "primary": "#bef264",
      "primary_foreground": "#000000",
      "secondary": "#27272a",
      "secondary_foreground": "#fafafa",
      "muted": "#27272a",
      "muted_foreground": "#a1a1aa",
      "accent": "#27272a",
      "accent_foreground": "#fafafa",
      "destructive": "#ef4444",
      "border": "#27272a",
      "input": "#27272a",
      "ring": "#bef264"
    },
    "usage": {
      "brand": "Primary (Lime) for CTAs, Active States, and Progress Bars.",
      "surface": "Card (Zinc 900) for containers.",
      "background": "Background (Zinc 950) for the main canvas.",
      "text": "Foreground (Zinc 50) for primary text, Muted Foreground (Zinc 400) for secondary."
    }
  },
  "layout": {
    "container": "max-w-md mx-auto min-h-screen bg-background relative overflow-hidden shadow-2xl",
    "spacing": {
      "page_padding": "p-6",
      "section_gap": "gap-8",
      "item_gap": "gap-4"
    },
    "grid_strategy": "Bento Grid for Dashboard (mix of 1x1, 2x1, 2x2 cells). Stack for Lists."
  },
  "components": {
    "library": "Shadcn/UI",
    "customizations": [
      "Buttons: Rounded-full (pill) for primary actions, Rounded-lg for secondary.",
      "Cards: No shadow, 1px border (border-white/10), rounded-xl.",
      "Inputs: Height 56px (h-14) for touch targets, filled style (bg-secondary/50).",
      "Navigation: Bottom Tab Bar (Fixed) with blur effect (backdrop-blur-xl)."
    ],
    "paths": {
      "ui": "/app/frontend/src/components/ui",
      "components": "/app/frontend/src/components"
    }
  },
  "features": {
    "auth": {
      "endpoints": ["/api/auth/login", "/api/auth/register", "/api/auth/google/session"],
      "design": "Minimalist form, centered, large inputs."
    },
    "onboarding": {
      "endpoints": ["/api/onboarding/recommendations", "/api/onboarding/complete"],
      "design": "Multi-step wizard (Carousel or Stepper). Questions: Gender, Fitness Level, Goal. Result: Plan Selection."
    },
    "dashboard": {
      "endpoints": ["/api/dashboard"],
      "design": "Bento Grid. 'Streak' (Fire icon), 'Today's Workout' (Card with Image), 'Habits' (Checklist)."
    },
    "workouts": {
      "endpoints": ["/api/plans", "/api/plans/{id}", "/api/workouts/start", "/api/workouts/active", "/api/workouts/complete"],
      "design": "List of Cards with Hero Images. Active Workout: Timer overlay, big checkboxes for sets."
    },
    "habits": {
      "endpoints": ["/api/habits", "/api/habits/{id}/today"],
      "design": "Simple list items with swipe-to-complete or tap-to-toggle."
    },
    "analytics": {
      "endpoints": ["/api/analytics"],
      "design": "Bar Charts (Recharts) showing completion trends."
    }
  },
