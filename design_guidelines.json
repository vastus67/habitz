  "instructions_to_main_agent": [
    "1. UPDATE tailwind.config.js and index.css with the colors defined above.",
    "2. INSTALL required packages: `lucide-react`, `recharts`, `date-fns`, `framer-motion`, `clsx`, `tailwind-merge`.",
    "3. CREATE a `Layout` component that includes a fixed Bottom Navigation Bar.",
    "4. IMPLEMENT pages in `src/pages/` mapped to the routes.",
    "5. USE `fetch` or `axios` to connect to the backend endpoints.",
    "6. USE `sonner` for all success/error notifications.",
    "7. ENSURE all interactive elements have `data-testid`."
  ],
  "UNIVERSAL_GUIDELINES_FOR_MAIN_AGENT": [
    "You tend to converge toward generic outputs. Avoid this.",
    "Dark colors look good when used independently without gradients.",
    "Use glass-morphism effects with backdrop filters (12-24px blur).",
    "Every interaction needs micro-animations.",
    "Use 2-3x more spacing than feels comfortable.",
    "Prioritize using pre-existing components from src/components/ui.",
    "Use sonner for toasts.",
    "Use Lucide React for icons.",
    "Use Recharts for charts."
  ]
}